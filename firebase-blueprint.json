{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "description": "User profile and gamification stats",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "photoURL": { "type": "string" },
        "xp": { "type": "number", "description": "Experience points" },
        "level": { "type": "number", "description": "Current level" },
        "rank": { "type": "string", "enum": ["E", "D", "C", "B", "A", "S", "SS", "SSS", "GOD"] },
        "coins": { "type": "number", "description": "Gold currency" },
        "voidCrystals": { "type": "number", "description": "Premium currency" },
        "abyssalDust": { "type": "number", "description": "Dust from burning cards" },
        "energy": { "type": "number", "description": "Sanity/Energy" },
        "lastLogin": { "type": "string", "format": "date-time" },
        "nsfwEnabled": { "type": "boolean" },
        "role": { "type": "string", "enum": ["admin", "user"] },
        "inventory": { "type": "array", "items": { "type": "object" }, "description": "The items the user owns, including durability and merge level." },
        "pityCounters": { "type": "object", "description": "Pity counters for different banners." },
        "lastTaxTime": { "type": "string", "format": "date-time", "description": "Last time the wealth tax was applied." },
        "protectionWardUntil": { "type": "string", "format": "date-time", "description": "Expiration time of the protection ward." },
        "abyssFloor": { "type": "number", "description": "Current floor in the Infinite Abyss." },
        "abyssRewards": { "type": "object", "description": "Accumulated rewards in the current Abyss run." },
        "lastRaid": { "type": "string", "format": "date-time", "description": "Last time the user raided." },
        "lastGateEntry": { "type": "string", "format": "date-time", "description": "Last time the user entered a gate." },
        "worldBossDamage": { "type": "number", "description": "Damage dealt to the current world boss." },
        "lastPassiveReward": { "type": "string", "format": "date-time", "description": "Last time passive XP/Energy was granted." },
        "weeklyTimeSpent": { "type": "number", "description": "Time spent this week in minutes." }
      },
      "required": ["uid", "xp", "level", "rank", "coins", "voidCrystals", "abyssalDust", "energy", "lastLogin", "nsfwEnabled", "role", "pityCounters"]
    },
    "PublicProfile": {
      "title": "PublicProfile",
      "description": "Publicly visible user data",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "nickname": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "xp": { "type": "number" },
        "level": { "type": "number" },
        "rank": { "type": "string" },
        "coins": { "type": "number" },
        "energy": { "type": "number" },
        "weeklyTimeSpent": { "type": "number" },
        "profileBanner": { "type": "string" },
        "championWeek": { "type": "string" }
      },
      "required": ["uid", "xp", "level", "rank"]
    },
    "Guild": {
      "title": "Guild",
      "description": "A group of users",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "leaderId": { "type": "string" },
        "members": { "type": "array", "items": { "type": "string" } },
        "xp": { "type": "number" },
        "level": { "type": "number" },
        "controlledPages": { "type": "array", "items": { "type": "string" }, "description": "Anime/Manga pages controlled by the guild." },
        "goldPool": { "type": "number", "description": "Gold accumulated by the guild." }
      },
      "required": ["name", "leaderId", "members", "xp", "level", "goldPool"]
    },
    "WorldBoss": {
      "title": "WorldBoss",
      "description": "Global Calamity event",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "maxHp": { "type": "number" },
        "currentHp": { "type": "number" },
        "spawnTime": { "type": "string", "format": "date-time" },
        "endTime": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["active", "defeated", "failed"] },
        "participants": { "type": "object", "additionalProperties": { "type": "number" }, "description": "Map of userId to damage dealt." }
      },
      "required": ["name", "maxHp", "currentHp", "spawnTime", "endTime", "status"]
    },
    "Territory": {
      "title": "Territory",
      "description": "Anime/Manga page controlled by a guild",
      "type": "object",
      "properties": {
        "mediaId": { "type": "number" },
        "mediaTitle": { "type": "string" },
        "mediaCover": { "type": "string" },
        "controllingGuildId": { "type": "string" },
        "controllingGuildName": { "type": "string" },
        "highestBid": { "type": "number" },
        "lastBidAt": { "type": "string", "format": "date-time" }
      },
      "required": ["mediaId", "mediaTitle", "controllingGuildId", "controllingGuildName", "highestBid", "lastBidAt"]
    },
    "WeeklyWinner": {
      "title": "WeeklyWinner",
      "description": "Winner of the weekly leaderboard",
      "type": "object",
      "properties": {
        "winnerId": { "type": "string" },
        "winnerName": { "type": "string" },
        "score": { "type": "number" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["winnerId", "winnerName", "score", "timestamp"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/UserProfile" },
      "description": "User profiles"
    },
    "/guilds/{guildId}": {
      "schema": { "$ref": "#/entities/Guild" },
      "description": "Guilds"
    },
    "/worldBosses/{bossId}": {
      "schema": { "$ref": "#/entities/WorldBoss" },
      "description": "Active and past world bosses"
    },
    "/territories/{territoryId}": {
      "schema": { "$ref": "#/entities/Territory" },
      "description": "Territory Wars data"
    },
    "/weekly_winners/{weekId}": {
      "schema": { "$ref": "#/entities/WeeklyWinner" },
      "description": "History of weekly winners"
    },
    "/public_profiles/{userId}": {
      "schema": { "$ref": "#/entities/PublicProfile" },
      "description": "Publicly visible user profiles for leaderboard"
    }
  }
}
